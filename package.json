{
  "name": "score-more-finale",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next": "^16.2.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@orpc/server": "^1.12.2",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "db:push": "bun run --filter @score-more-finale/db db:push",
    "db:studio": "bun run --filter @score-more-finale/db db:studio",
    "db:generate": "bun run --filter @score-more-finale/db db:generate",
    "db:migrate": "bun run --filter @score-more-finale/db db:migrate",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@score-more-finale/env": "workspace:*",
    "dotenv": "catalog:",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "marked": "^18.0.2",
    "react-pdf-html": "^2.1.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@score-more-finale/config": "workspace:*",
    "@types/marked": "^6.0.0",
    "@types/node": "^22.13.14",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.5"
}
